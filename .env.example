# Local development identity — copy to .env and fill in your own values.
# .env is git-ignored; this file is a template only. Never put real secrets here.

# Git commit identity (use your GitHub no-reply email to avoid leaking it)
GIT_USER_NAME=your-handle
GIT_USER_EMAIL=1234567+your-handle@users.noreply.github.com

# Optional: path that scripts/setup.sh will set as core.hooksPath
GIT_HOOKS_PATH=.githooks
