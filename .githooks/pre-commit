#!/usr/bin/env bash
# Block direct commits to protected branches. Use a feature branch + worktree.
set -euo pipefail

branch="$(git symbolic-ref --short HEAD 2>/dev/null || echo '')"

protected_re='^(main|master|dev|release/.*)$'
if [[ "$branch" =~ $protected_re ]]; then
  if [[ "${ALLOW_DIRECT_COMMIT:-0}" != "1" ]]; then
    cat >&2 <<'EOF'
✖ commit blocked: direct commits to this branch are not allowed.

This repo uses a worktree-only policy:
  • the main checkout stays on main/dev for fetch/pull only — no edits
  • all editing happens in a dedicated side worktree on a feature branch
  • every change reaches main/dev through a pull request

Create a side worktree for your topic:
    git fetch origin
    git worktree add ../claude-cat.<kind>-<topic> -b <kind>/<topic> origin/dev
    cd ../claude-cat.<kind>-<topic>
    # ... edit, commit, push ...
    gh pr create --base dev --head <kind>/<topic>

<kind> is one of: feat | fix | chore | docs | refactor | test. One topic
per worktree so CodeRabbit + reviewers see a single coherent change.

(Bypass once with ALLOW_DIRECT_COMMIT=1 — reserved for repo bootstrap.)
EOF
    exit 1
  fi
fi

# Lightweight secret scan — best-effort only.
staged="$(git diff --cached --name-only --diff-filter=ACM || true)"
if [[ -n "$staged" ]]; then
  # Reject real env/credential files, but allow the .env.example template.
  bad="$(printf '%s\n' "$staged" | grep -E '(^|/)(\.env(\..*)?|.*\.pem|.*\.p8|.*\.p12|\.credentials\.json)$' | grep -vE '(^|/)\.env\.example$' || true)"
  if [[ -n "$bad" ]]; then
    echo "✖ commit blocked: secret-looking file staged." >&2
    printf '%s\n' "$bad" >&2
    exit 1
  fi
  # Scan diff for common secret patterns.
  if git diff --cached -U0 | grep -E '(sk-ant-[A-Za-z0-9_-]{20,}|ghp_[A-Za-z0-9]{20,}|gho_[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16})' >/dev/null; then
    echo "✖ commit blocked: possible secret found in staged diff." >&2
    exit 1
  fi
fi
